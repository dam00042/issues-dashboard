{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DASHBOARD_API_PORT",
    "NEXT_PUBLIC_API_BASE_URL"
  ],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "release/**",
        "release-portable/**",
        "build/**",
        "out/**"
      ]
    },
    "lint": {
      "outputs": []
    },
    "format": {
      "cache": false,
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": []
    }
  }
}

